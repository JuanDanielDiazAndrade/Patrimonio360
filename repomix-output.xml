                                                aria-describedby="emailError"
                                                className={inputClass('email')}
                                            />
                                        </div>
                                        {/* Mensaje de error: solo se renderiza si hay un error */}
                                        {errors.email && (
                                            <p id="emailError" className="text-red-500 text-xs mt-1" role="alert">
